# Target Galaxy instance
GALAXY_URL=https://<your-galaxy-instance>/
API_KEY=<your-api-key>

# The id_secret of the target Galaxy instance (used to encode/decode object IDs)
ID_SECRET="<target-id-secret>"

# Path to Galaxy's scripts/ directory on this machine — cast.sh derives the venv from here:
GALAXY_SOURCE=/<you>/galaxy/scripts/

# File to read when testing path traversal
TARGET_FILE=/etc/passwd

# For spells targeting instances running the default id_secret
SPELL_ID_SECRET="USING THE DEFAULT IS NOT SECURE!"
